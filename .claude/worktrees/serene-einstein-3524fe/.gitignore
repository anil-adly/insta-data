# ---- Secrets & env ----
.env
.env.*
!.env.example

# ---- Dependencies ----
node_modules/

# ---- Crawler runtime artifacts (local only, never deployed) ----
downloads/
auth/
data/*.sqlite
data/*.sqlite-journal
data/*.sqlite-wal
data/*.sqlite-shm
*.db
*.sqlite

# ---- Raw media (local only) ----
*.mp4
*.mp3
*.m4a
*.webm

# ---- OS noise ----
.DS_Store

# ---- Dashboard published assets (generated by dashboard/build.mjs) ----
# These are intentionally committed so Netlify can serve them, so re-include
# them after the broad media/db ignores above.
!dashboard/audio/
!dashboard/audio/*.m4a
!dashboard/data.json
