# Instagram credentials
INSTAGRAM_USERNAME=your_username_here
INSTAGRAM_PASSWORD=your_password_here

# Download settings
DOWNLOAD_DIR=./downloads
# Max number of videos to list from search results
MAX_RESULTS=10

# Search pagination settings
# Max scroll rounds while collecting search results
SEARCH_MAX_SCROLL_ROUNDS=150
# Stop after this many rounds with no newly discovered links
SEARCH_NO_NEW_ROUNDS=8
# Safety cap for total unique links collected from a search
SEARCH_MAX_COLLECTED=2000
# Fallback verification limit if Instagram grid does not expose video markers
SEARCH_VERIFY_LIMIT=300
